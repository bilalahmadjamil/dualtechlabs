# Set these in Vercel: Project → Settings → Environment Variables
# (add for Production and Preview; use your real preview URL for NEXT_PUBLIC_SITE_URL on Preview if needed)

# Canonical URL — must match the URL users see (include www if you redirect apex → www). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.dualtechlabs.com

# Optional: Google Search Console → Settings → Ownership verification (meta tag “content” value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Public contact — exposed to the browser (NEXT_PUBLIC_*)
NEXT_PUBLIC_CONTACT_EMAIL=info@dualtechlabs.com
NEXT_PUBLIC_WHATSAPP_PHONE=+923204749700
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hello, I would like to inquire about DualTech Labs services.
